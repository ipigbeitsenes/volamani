# ──────────────────────────────────────────────────────────────
# Volamani — Namecheap cPanel (shared hosting) production template
# Copy to .env on the server, fill in the CAPS values, then:
#   php artisan key:generate
# Shared hosting has no Redis, so cache/session/queue use the database.
# ──────────────────────────────────────────────────────────────

APP_NAME=Volamani
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://YOURDOMAIN.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ── Database (create in cPanel › MySQL Databases; note the cPanelUser_ prefix) ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=CPANELUSER_volamani
DB_USERNAME=CPANELUSER_dbuser
DB_PASSWORD=YOUR_DB_PASSWORD

# ── No Redis on shared hosting → database / file drivers ──
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true          # requires working HTTPS first (enable AutoSSL)
CACHE_STORE=database
QUEUE_CONNECTION=database           # processed by the cron queue worker
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ── Mail (use a cPanel email account's SMTP) ──
MAIL_MAILER=smtp
MAIL_HOST=mail.YOURDOMAIN.com
MAIL_PORT=465
MAIL_USERNAME=help@YOURDOMAIN.com
MAIL_PASSWORD=YOUR_MAILBOX_PASSWORD
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=help@YOURDOMAIN.com
MAIL_FROM_NAME="${APP_NAME}"

# ── Payments — Paystack (use LIVE keys) ──
PAYSTACK_PUBLIC_KEY=pk_live_xxx
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_CALLBACK_URL="${APP_URL}/checkout/callback"
PAYMENT_GATEWAY=paystack
PLATFORM_FEE_PERCENT=10

# Manual bank-transfer details shown at checkout (optional)
BANK_NAME=
BANK_ACCOUNT_NAME=
BANK_ACCOUNT_NUMBER=

# ── Display currency (admin-configurable; default USD) ──
# These are only defaults — the live values live in Settings.
# CURRENCY is controlled from the admin Settings panel, not here.

# ── Database backups (nightly db:backup; needs mysqldump, present on cPanel) ──
BACKUP_DISK=local                   # point at S3 for real off-box DR
BACKUP_RETENTION_DAYS=14

# If your real document root (public_html) is a separate folder from the app's
# public/ dir (and LiteSpeed won't serve through the storage symlink), point the
# public disk at the docroot's real /storage folder so uploads/images serve:
# PUBLIC_DISK_ROOT=/home/YOURUSER/public_html/storage

# ── Storage (leave local unless you wire S3 in admin Settings) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
