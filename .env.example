# ──────────────────────────────────────────────────────────────
# Volamani environment template
# Copy to .env and fill in values. PRODUCTION CHECKLIST at bottom.
# ──────────────────────────────────────────────────────────────

APP_NAME=Volamani
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (Docker service name "mysql"; use 127.0.0.1:3307 when running natively)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=volamani
DB_USERNAME=volamani
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (local dev: host=mailpit port=1025 encryption=null)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=help@volamani.com
MAIL_FROM_NAME="${APP_NAME}"

# Payments — Paystack (use sk_live_/pk_live_ keys in production)
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL="${APP_URL}/checkout/callback"
PAYMENT_GATEWAY=paystack
PLATFORM_FEE_PERCENT=10

# Manual bank-transfer details shown at checkout
BANK_NAME=
BANK_ACCOUNT_NAME=
BANK_ACCOUNT_NUMBER=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Database backups (php artisan db:backup runs nightly at 01:30).
# Point BACKUP_DISK at an off-box disk (e.g. s3) in production — a backup on the
# same box as the DB is not disaster recovery.
BACKUP_DISK=local
BACKUP_RETENTION_DAYS=14

# Error tracking. The app already attaches request context to logged exceptions;
# to ship them to Sentry, run `composer require sentry/sentry-laravel` and set:
SENTRY_LARAVEL_DSN=

VITE_APP_NAME="${APP_NAME}"

# ──────────────────────────────────────────────────────────────
# PRODUCTION CHECKLIST — set these before going live:
#   APP_ENV=production
#   APP_DEBUG=false              (NEVER true in prod — leaks secrets on errors)
#   APP_URL=https://...          (HTTPS is forced when APP_ENV=production)
#   LOG_LEVEL=warning
#   SESSION_ENCRYPT=true
#   SESSION_SECURE_COOKIE=true   (cookies only over HTTPS)
#   QUEUE_CONNECTION=redis       (+ run queue workers; sync blocks requests)
#   CACHE_STORE=redis
#   SESSION_DRIVER=redis
#   DB_PASSWORD / MAIL_PASSWORD / PAYSTACK_SECRET_KEY from a secrets manager,
#     not committed anywhere.
#   Seeder admin passwords (AdminUserSeeder) MUST be rotated after first deploy.
#   Run: php artisan config:cache route:cache view:cache event:cache
# ──────────────────────────────────────────────────────────────
